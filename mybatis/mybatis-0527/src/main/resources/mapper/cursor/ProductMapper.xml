<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatis.cursor.mapper.ProductMapper">

    <!--
        【游标查询示例3】通过XML配置游标查询

        关键配置：
        1. resultSetType="FORWARD_ONLY" - 结果集只向前滚动
        2. fetchSize="-1" - 等同于Integer.MIN_VALUE，表示逐行读取

        这种配置方式适用于复杂的SQL，无法用注解表达的情况
    -->
    <select id="selectAllProductsByCursor"
            resultType="com.example.mybatis.cursor.entity.Product"
            resultSetType="FORWARD_ONLY"
            fetchSize="-1">
        SELECT id, name, category, price, stock, status, create_time, update_time
        FROM t_product
        ORDER BY id
    </select>

</mapper>
